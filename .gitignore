# Python caches and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.venv*/
build/
core/executables_or_wrappers/runtime/**/.conda-scram-build/

# Runtime outputs generated by ProgramSCRAM
RESULT/
core/executables_or_wrappers/runtime/**/RESULT/
core/executables_or_wrappers/runtime/**/results/
install_logs/
scram-boxapp
dist/

# Fortran/SCons build products inside bundled SCRAM source trees
*.o
*.mod
*.smod
.sconsign.dblite
.sconf_temp/
core/executables_or_wrappers/runtime/*/source/**/ProgramSCRAM
core/executables_or_wrappers/runtime/*/source/**/ProgramSCRAM.exe

# Ops library SWIG/SCons generated files (not committed, rebuilt locally)
**/include/ops/_ops.so
**/include/ops/ops.py
**/include/ops/ops_wrap.cc
**/include/ops/ops_wrap.os

# Local logs and scratch files
*.log
*.tmp
*.bak
*~
